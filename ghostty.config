# Shirotelin Theme for Ghostty

theme = dark

# Background & Foreground
background = #ffffff
foreground = #000000

# Cursor
cursor-color = #87005f
cursor-style = block
cursor-vibe = terminal

# Selection
selection-background = #cde8ff
selection-foreground = #000000

# ANSI Colors (adapted from shirotelin)
color-0 = #000000  # black
color-1 = #87005f  # red (purple)
color-2 = #5f00    # green
color-3 = #5f      # yellow (light green)
color-4 = #af      # blue (light green)
color-5 = #af00af  # magenta (pink)
color-6 = #5f      # cyan
color-7 = #545454  # white (gray)

# Bright ANSI Colors
color-8 = #545454  # bright black
color-9 = #87005f  # bright red
color-10 = #5f00   # bright green
color-11 = #af     # bright yellow
color-12 = #af     # bright blue
color-13 = #af00af # bright magenta
color-14 = #5f     # bright cyan
color-15 = #ffffff # bright white

# Mouse
mouse-color = #87005f
mouse-text-color = #ffffff

# Hyperlink
hyperlink-color = #af00af

# Search
search-match-background = #cde8ff
search-match-foreground = #000000

# Scrollbar
scrollbar-color = #545454
scrollback = 10000
mouse-scroll-speed = 3