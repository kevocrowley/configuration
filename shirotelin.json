{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "shiroWhite": "#ffffff",
    "shiroBlack": "#000000",
    "shiroPurple": "#87005f",
    "shiroGreen": "#5f00",
    "shiroLightGreen": "#5f",
    "shiroLightGreen2": "#af",
    "shiroGray": "#545454",
    "shiroSelection": "#cde8ff",
    "shiroLineNumber": "#545454",
    "shiroPink": "#af00af"
  },
  "theme": {
    "primary": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "secondary": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "accent": {
      "dark": "shiroPink",
      "light": "shiroPink"
    },
    "error": {
      "dark": "#ff0000",
      "light": "#ff0000"
    },
    "warning": {
      "dark": "#d08770",
      "light": "#d08770"
    },
    "success": {
      "dark": "#a3be8c",
      "light": "#a3be8c"
    },
    "info": {
      "dark": "shiroLightGreen2",
      "light": "shiroPurple"
    },
    "text": {
      "dark": "shiroBlack",
      "light": "shiroBlack"
    },
    "textMuted": {
      "dark": "shiroGray",
      "light": "shiroGray"
    },
    "background": {
      "dark": "shiroWhite",
      "light": "shiroWhite"
    },
    "backgroundPanel": {
      "dark": "#f5f5f5",
      "light": "#f5f5f5"
    },
    "backgroundElement": {
      "dark": "#eeeeee",
      "light": "#eeeeee"
    },
    "border": {
      "dark": "#dddddd",
      "light": "#dddddd"
    },
    "borderActive": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "borderSubtle": {
      "dark": "#eeeeee",
      "light": "#eeeeee"
    },
    "diffAdded": {
      "dark": "#a3be8c",
      "light": "#a3be8c"
    },
    "diffRemoved": {
      "dark": "#bf616a",
      "light": "#bf616a"
    },
    "diffContext": {
      "dark": "shiroGray",
      "light": "shiroGray"
    },
    "diffHunkHeader": {
      "dark": "#e5e9f0",
      "light": "#e5e9f0"
    },
    "diffHighlightAdded": {
      "dark": "#a3be8c",
      "light": "#a3be8c"
    },
    "diffHighlightRemoved": {
      "dark": "#bf616a",
      "light": "#bf616a"
    },
    "diffAddedBg": {
      "dark": "#e5f5e5",
      "light": "#e5f5e5"
    },
    "diffRemovedBg": {
      "dark": "#ffc8c8",
      "light": "#ffc8c8"
    },
    "diffContextBg": {
      "dark": "shiroWhite",
      "light": "shiroWhite"
    },
    "diffLineNumber": {
      "dark": "shiroGray",
      "light": "shiroGray"
    },
    "diffAddedLineNumberBg": {
      "dark": "#c8ffc8",
      "light": "#c8ffc8"
    },
    "diffRemovedLineNumberBg": {
      "dark": "#ffc8c8",
      "light": "#ffc8c8"
    },
    "markdownText": {
      "dark": "shiroBlack",
      "light": "shiroBlack"
    },
    "markdownHeading": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "markdownLink": {
      "dark": "shiroPink",
      "light": "shiroPink"
    },
    "markdownLinkText": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "markdownCode": {
      "dark": "shiroLightGreen2",
      "light": "shiroLightGreen2"
    },
    "markdownBlockQuote": {
      "dark": "shiroGreen",
      "light": "shiroGreen"
    },
    "markdownEmph": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "markdownStrong": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "markdownHorizontalRule": {
      "dark": "shiroGray",
      "light": "shiroGray"
    },
    "markdownListItem": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "markdownListEnumeration": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "markdownImage": {
      "dark": "shiroPink",
      "light": "shiroPink"
    },
    "markdownImageText": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "markdownCodeBlock": {
      "dark": "shiroBlack",
      "light": "shiroBlack"
    },
    "syntaxComment": {
      "dark": "shiroGreen",
      "light": "shiroGreen"
    },
    "syntaxKeyword": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "syntaxFunction": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "syntaxVariable": {
      "dark": "shiroBlack",
      "light": "shiroBlack"
    },
    "syntaxString": {
      "dark": "shiroLightGreen2",
      "light": "shiroLightGreen2"
    },
    "syntaxNumber": {
      "dark": "shiroLightGreen2",
      "light": "shiroLightGreen2"
    },
    "syntaxType": {
      "dark": "shiroLightGreen",
      "light": "shiroLightGreen"
    },
    "syntaxOperator": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    },
    "syntaxPunctuation": {
      "dark": "shiroPurple",
      "light": "shiroPurple"
    }
  }
}
